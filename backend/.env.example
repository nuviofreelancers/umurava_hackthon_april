# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/talentscreen?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<replace-with-a-long-random-secret-min-64-chars>
JWT_EXPIRES_IN=7d

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>
# Model: gemini-2.5-flash recommended (fast + cost-effective)
GEMINI_MODEL=gemini-2.5-flash

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Allowed frontend origin for CORS (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# ─── Email / SMTP (optional) ──────────────────────────────────────────────────
# Leave blank to disable email features — the app will still run fine
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email@gmail.com>
SMTP_PASS=<your-gmail-app-password>
SMTP_FROM=TalentScreen <noreply@yourcompany.com>

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max requests per window per IP (applies to all routes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
# Stricter limit for AI upload endpoints (costs money)
UPLOAD_RATE_LIMIT_MAX=10
