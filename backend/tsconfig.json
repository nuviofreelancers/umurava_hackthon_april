{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedModules": true
  },
  "include": [
    "src/**/*",
    "routes/**/*",
    "controllers/**/*",
    "models/**/*",
    "config/**/*",
    "middlewares/**/*",
    "services/**/*",
    "utils/**/*"
, "server.ts"  ],
  "exclude": ["node_modules", "dist", "scripts"]
}